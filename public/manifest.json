{
  "manifest_version": 3,
  "name": "donuTool",
  "version": "1.0.6",
  "description": "donuTool is a floating cursor-following toolbar that offers instant, overlay-based access to essential tools.",
  "icons": {
    "16": "assets/donuTool-logo-white.png",
    "32": "assets/donuTool-logo-white.png",
    "48": "assets/donuTool-logo-white.png",
    "128": "assets/donuTool-logo-white.png"
  },
  "oauth2": {
    "client_id": "REMOVED",
    "scopes": [""]
  },
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/donuToolBar.png", "assets/*.svg", "overlay/*.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs",
    "bookmarks",
    "clipboardWrite",
    "downloads",
    "identity"
  ],
  "host_permissions": ["<all_urls>"],
  "key": "REMOVED"
}
